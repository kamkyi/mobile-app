# Public variables are bundled into the client. Do not add API keys here.
EXPO_PUBLIC_WORKOS_CLIENT_ID=client_01_example_replace_me
EXPO_PUBLIC_WORKOS_API_HOSTNAME=api.workos.com
EXPO_PUBLIC_WORKOS_REDIRECT_URI=
EXPO_PUBLIC_WORKOS_REDIRECT_SCHEME=mobile
EXPO_PUBLIC_WORKOS_REDIRECT_PATH=auth/callback
EXPO_PUBLIC_WORKOS_WEB_REDIRECT_URI=

# Optional AuthKit hints
EXPO_PUBLIC_WORKOS_ORGANIZATION_ID=
EXPO_PUBLIC_WORKOS_CONNECTION_ID=
EXPO_PUBLIC_WORKOS_DOMAIN_HINT=
EXPO_PUBLIC_WORKOS_LOGIN_HINT=
EXPO_PUBLIC_WORKOS_WEB_REDIRECT_URI=https://kamkyi.github.io/mobile-app/auth/callback